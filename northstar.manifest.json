{
  "applicationId": "QMSP-CAPA-001",
  "name": "Corrective Action & CAPA",
  "product": "QMSPilot Northstar",
  "version": "1.1.0",
  "entrypoint": "index.html",
  "category": "Quality Execution",
  "systemOfRecord": "Northstar",
  "standaloneMode": true,
  "offlineQueue": true,
  "recordSchema": "schemas/capa-record.schema.json",
  "requiredContext": ["tenantId", "user", "site", "permissions"],
  "permissions": [
    "capa.read",
    "capa.create",
    "capa.update",
    "capa.submit",
    "capa.approve",
    "capa.close",
    "evidence.upload"
  ],
  "ui": {
    "dashboard": {
      "enabled": true,
      "location": "Northstar Workforce",
      "metrics": ["readiness", "openActions", "overdueActions", "totalCOPQ"],
      "workforceStatus": ["Pilot", "Atlas", "Forge", "Sentinel", "Vector"]
    },
    "demo": {
      "currentPresentation": "floating-card",
      "futurePresentation": "northstar-toolbox-tile",
      "component": "src/demo-card.js"
    }
  },
  "futureTile": {
    "title": "Corrective Action & CAPA",
    "shortTitle": "CAPA",
    "category": "Quality Execution",
    "icon": "corrective-action",
    "launchMode": "northstar-application",
    "badgeSources": ["openActions", "overdueActions", "pendingApprovals"]
  },
  "modules": {
    "storage": "src/storage.js",
    "validation": "src/validation.js",
    "northstarSdk": "src/northstar-sdk.js",
    "dashboard": "src/dashboard.js",
    "demoCard": "src/demo-card.js"
  },
  "workforce": {
    "Pilot": ["orchestrate", "summarize", "escalate"],
    "Atlas": ["create_actions", "track_due_dates", "escalate_overdue"],
    "Forge": ["review_problem_statement", "review_root_cause", "review_actions"],
    "Sentinel": ["review_compliance", "review_evidence", "gate_closure"],
    "Vector": ["review_extent", "recommend_systemic_actions", "capture_lessons"]
  },
  "events": {
    "ready": "QMSPILOT_MICROTOOL_READY",
    "context": "QMSPILOT_CONTEXT",
    "submit": "QMSPILOT_SUBMIT_TO_NORTHSTAR",
    "confirmed": "QMSPILOT_SUBMISSION_CONFIRMED",
    "demoLaunched": "QMSPILOT_CAPA_DEMO_LAUNCHED"
  }
}
